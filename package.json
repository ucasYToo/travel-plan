{
  "name": "trip-packer",
  "version": "1.0.5",
  "description": "Build standalone travel map HTML from JSON itinerary data",
  "type": "module",
  "bin": {
    "trip-packer": "bin/trip-packer.js"
  },
  "files": [
    "bin",
    "dist/cli",
    "src",
    "scripts",
    "css",
    "README.md",
    "index.html",
    "vite.config.ts",
    "tsconfig.json",
    "tsconfig.node.json",
    "package.json"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:cli": "tsc -p tsconfig.cli.json",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "rm -f dist/index.html && npm run build:cli"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "clsx": "^2.1.1",
    "commander": "^12.1.0",
    "leaflet": "^1.9.4",
    "modern-screenshot": "^4.6.8",
    "picocolors": "^1.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^4.2.1",
    "vite": "^5.1.4",
    "vite-plugin-singlefile": "^2.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@types/leaflet": "^1.9.8",
    "@types/node": "^20.19.39",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitest/coverage-v8": "^1.6.0",
    "jimp": "^1.6.1",
    "jsdom": "^24.0.0",
    "playwright-core": "^1.59.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}
